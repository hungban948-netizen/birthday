# ── Cấu hình ──────────────────────────────────────────
TEN  = "Tên Bạn"   # 👈 Đổi tên tại đây
TUOI = 21
NGAY = "11/06/2005"
# ──────────────────────────────────────────────────────

console = Console()
W = console.width or 80

RAINBOW = ["#ff0080","#ff6bcb","#ff6600","#fbbf24","#00ff88","#00ffff","#a78bfa","#ff00ff"]
SPARKS  = ["✦","✧","★","✶","✸","✹","❋","❊","✺","⚡","💥","🌟","✨","🎆","🎇"]

def rainbow(text):
    t = Text()
    for i, ch in enumerate(text):
        t.append(ch, style=RAINBOW[i % len(RAINBOW)])
    return t

def glitch_text(text):
    glitch_chars = "!@#$%^&*<>?/\\|~`"
    result = ""
    for ch in text:
        if random.random() < 0.15 and ch != " ":
            result += random.choice(glitch_chars)
        else:
            result += ch
    return result

def typing_rainbow(text, delay=0.03):
    colors = RAINBOW * 10
    for i, ch in enumerate(text):
        console.print(ch, style=f"bold {colors[i % len(colors)]}", end="")
        time.sleep(delay)
    print()

def firework_burst(x_center=None, rows=6):
    if x_center is None:
        x_center = W // 2
    shapes = []
    for r in range(rows):
        line = [" "] * W
        n = r * 4 + 4
        for _ in range(n):
            angle_idx = random.randint(0, 359)
            import math
            rad = math.radians(angle_idx)
            px = int(x_center + r * 2.5 * math.cos(rad))
            py_off = int(r * 1.2 * math.sin(rad))
            if 0 <= px < W:
                line[px] = random.choice(SPARKS)
        shapes.append(("".join(line), r))
    return shapes

def show_firework():
    cx = W // 2
    for step in range(8):
        t = Text()
        import math
        for _ in range(3):
            line = [" "] * min(W, 120)
            n = step * 6 + 6
            for _ in range(n):
                angle = random.uniform(0, math.pi * 2)
                dist = step * 2.5
                px = int(cx + dist * math.cos(angle))
                if 0 <= px < len(line):
                    line[px] = random.choice(SPARKS)
            color = RAINBOW[step % len(RAINBOW)]
            t.append("".join(line) + "\n", style=f"bold {color}")
        console.print(Align.center(t))
        time.sleep(0.05)

def ascii_heart():
    heart = [
        "  ██████   ██████  ",
        " ████████ ████████ ",
        " █████████████████ ",
        "  ███████████████  ",
        "   █████████████   ",
        "    ███████████    ",
        "     █████████     ",
        "      ███████      ",
        "       █████       ",
        "        ███        ",
        "         █         ",
    ]
    for i, line in enumerate(heart):
        color = RAINBOW[i % len(RAINBOW)]
        console.print(Align.center(Text(line, style=f"bold {color}")))
        time.sleep(0.06)

def separator():
    chars = "═╔╗╚╝║╠╣╦╩╬"
    line = ""
    for i in range(min(W, 80)):
        line += random.choice("═─━")
    t = Text()
    for i, ch in enumerate(line):
        t.append(ch, style=RAINBOW[i % len(RAINBOW)])
    console.print(Align.center(t))

def glitch_reveal(text, final_color="#ffffff"):
    steps = 8
    for step in range(steps):
        g = ""
        for ch in text:
            if step < steps - 1 and random.random() < (1 - step/steps) and ch != " ":
                g += random.choice("!@#$%^&*<>/\\|~")
            else:
                g += ch
        color = RAINBOW[step % len(RAINBOW)]
        console.print(f"\r  {g}", style=f"bold {color}", end="")
        time.sleep(0.07)
    console.print(f"\r  {text}", style=f"bold {final_color}")

def pulse_bar():
    bars = "▁▂▃▄▅▆▇█▇▆▅▄▃▂▁"
    for _ in range(3):
        t = Text()
        for i in range(min(W//2, 40)):
            ch = random.choice(bars)
            t.append(ch, style=RAINBOW[i % len(RAINBOW)])
        console.print(Align.center(t), end="\r")
        time.sleep(0.08)
    console.print()

def main():
    console.clear()

    # ── Intro pháo hoa ──
    for _ in range(3):
        show_firework()

    console.print()
    separator()
    console.print()

    # ── Glitch reveal tên ──
