    console.print()

    # ── Kết ──
    final = Text()
    msg = "🎊  HAPPY BIRTHDAY  🎊"
    for i, ch in enumerate(msg):
        final.append(ch, style=f"bold {RAINBOW[i % len(RAINBOW)]}")
    console.print(Align.center(final))
    console.print()

    # ── Countdown ──
    console.print(Align.center(Text("Tuổi mới bắt đầu trong...", style="#888888")))
    for i in range(3, 0, -1):
        t = Text(str(i), style=f"bold {RAINBOW[i % len(RAINBOW)]}")
        console.print(Align.center(t))
        time.sleep(0.8)
    console.print(Align.center(Text("🔥  LET'S GOOO!  🔥", style="bold #fbbf24")))
