    time.sleep(0.3)
    console.print()

    for _ in range(5):
        line = ""
        for i in range(min(W, 60)):
            line += random.choice("01 ")
        t = Text()
        for i, ch in enumerate(line):
            t.append(ch, style=RAINBOW[i % len(RAINBOW)])
        console.print(Align.center(t))
