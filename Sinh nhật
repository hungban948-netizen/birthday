    info.add_row("🔥  Slogan", "Tuổi 21 — Ngầu nhất vũ trụ!")
    console.print(Align.center(info))

    console.print()
    separator()
    console.print()

    # ── Lời chúc typing rainbow ──
    wishes = [
        "🌟  Chúc bạn luôn vui vẻ và hạnh phúc!",
        "🚀  Tuổi 21 — tự do, trẻ trung, đầy tiềm năng!",
        "💪  Chúc bạn thành công trên mọi con đường!",
        "❤️   Mọi ước mơ đều thành hiện thực!",
        "⚡  Ngầu nhất, xịn nhất, cháy nhất!",
    ]
    for wish in wishes:
